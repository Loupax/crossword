#!/usr/bin/env python3

import os
import time
import argparse
import random
import anthropic

# 1. Initialize the Anthropic client
client = anthropic.Anthropic()

# 2. The Cryptic, Yet Strict System Instruction
system_instruction = """
Name: Schwedenrätsel Clue Maker

Purpose and Goals:
Create highly accurate, ultra-short German crossword clues suitable for a traditional grid (Schwedenrätsel) based on CEFR levels and themes. The hints must be cleverly cryptic, but the vocabulary used in the hints MUST strictly adhere to the requested CEFR Hint Level.

Behaviors and Rules:

1) Grid Compatibility & Spelling (CRITICAL):
   - Divide words into 1/3 short (3-4 letters), 1/3 medium (5-7 letters), 1/3 long (8-12 letters).
   - Strongly favor answers containing common German intersection letters (E, N, I, S, R, A, T).
   - All ANSWERS must expand Umlaute and Eszett for a crossword grid (Ä->AE, Ö->OE, Ü->UE, ß->SS). Example: FRÜHLING becomes FRUEHLING.

2) Grammar Matching (CRITICAL):
   - The part of speech of the hint MUST match the answer.
   - If the answer is a Noun, the hint must be a Noun phrase (e.g., BAUM,"große Holzpflanze").
   - If the answer is a Verb, the hint must be an Infinitive Verb phrase (e.g., ARBEITEN,"beruflich tätig sein").
   - If the answer is an Adjective, the hint must be an Adjective (e.g., TRAURIG,"zutiefst betrübt").

3) Schwedenrätsel Brevity (CRITICAL):
   - Hints MUST be 1 to 3 words maximum. DO NOT use articles (der, die, das, ein, eine).

4) CEFR Calibrated Cryptic Tone (CRITICAL):
   - Hints must induce a 'productive struggle' through lateral thinking, NOT through advanced dictionary vocabulary.
   - The vocabulary used inside the hint MUST strictly match the requested Hint Level.
   - Do not use C1/C2 academic compound nouns (like 'Aggregatzustand' or 'Vegetationsperiode') if the requested hint level is A1, A2, or B1.
   - Create the struggle using simple words creatively (e.g., for DUSCHE at B1: use "schnelles Stehbad", not "Körperreinigungskabine").

5) Output Format:
   - Output ONLY raw CSV text. No markdown, no greetings, no explanation.
   - Format: WORD,"Hint"
   - Always use double quotes around hints. Never use single quotes.

6) The "Child/Basic" Definition Rule:

    To achieve the CEFR level, imagine explaining the word to a 10-year-old or someone with limited vocabulary.

    FORBIDDEN: Avoid words ending in '-wesen', '-stätte', '-träger', '-einheit', or '-gefüge'.

    FORBIDDEN: Avoid Latin/Internationalisms like 'optisch', 'akustisch', 'pharmazeutisch', 'digital', 'urban'. Use German descriptions instead.

    Bad Example (C1): KAMERA,"optischer Bildfänger"

    Good Example (B1): KAMERA,"macht Fotos" (Note: matches grammar rule) or "Gerät für Fotos".

7) Negative Constraints:

    If you find yourself using a word you would see in a law book or a scientific paper, DELETE it and use a word from a daily conversation.

8) Creativity Rule (CRITICAL):
   - DO NOT use direct dictionary definitions.
   - DO NOT just rewrite the word or use the root of the target word in the hint.
   - DO use situational clues, fill-in-the-blank idioms, analogies, or descriptions of utility.
   - Emulate real crossword puzzles: single-focus sentence fragments, punchy and lateral.
"""


# 3. Accept the themes array as a parameter
def run_bulk_generation(hint_difficulty, batch_size, themes):
    cefr_levels = ["A1", "A2", "B1"]
    random.shuffle(themes)
    generated_words = set()

    print(f"Starting generation | Hint Level: {hint_difficulty} | Batch Size: {batch_size}")
    print(f"Themes to process: {themes}\n")

    for level in cefr_levels:
        current_batch = 1
        total_batches_per_level = len(themes)

        for theme in themes:
            safe_theme = theme.replace(" ", "_")
            output_filename = f"crossword_{safe_theme}_{level}_{hint_difficulty}.csv"

            with open(output_filename, "a", encoding="utf-8") as file:
                prompt = (
                    f"Generate exactly {batch_size} German crossword word-and-hint pairs.\n"
                    f"Word Level: {level} (CEFR)\n"
                    f"Hint Level: {hint_difficulty} (CEFR)\n"
                    f"Theme: {theme}\n\n"
                    f"Length distribution (STRICT):\n"
                    f"- {batch_size // 3} short words (3-4 letters)\n"
                    f"- {batch_size // 3} medium words (5-7 letters)\n"
                    f"- {batch_size - 2 * (batch_size // 3)} long words (8-12 letters)\n\n"
                    f"Output ONLY raw CSV. Format: WORD,\"Hint\""
                )
                print(f"[{current_batch}/{total_batches_per_level}] Generating {theme} into {output_filename}...")

                try:
                    with client.messages.stream(
                        model="claude-opus-4-6",
                        max_tokens=4096,
                        thinking={"type": "adaptive"},
                        system=system_instruction,
                        messages=[{"role": "user", "content": prompt}],
                    ) as stream:
                        response = stream.get_final_message()

                    csv_data = ""
                    for block in response.content:
                        if block.type == "text":
                            csv_data = block.text.strip()
                            break

                    lines = csv_data.split('\n')
                    valid_lines = []
                    for line in lines:
                        line = line.strip()
                        if not line or ',' not in line:
                            continue
                        # Normalize: strip markdown fences or stray backticks
                        if line.startswith('```') or line.startswith('`'):
                            continue
                        word = line.split(',')[0].strip().upper()
                        if not word or word.startswith('#'):
                            continue
                        if word not in generated_words:
                            generated_words.add(word)
                            valid_lines.append(line)

                    if valid_lines:
                        file.write('\n'.join(valid_lines) + "\n")
                        file.flush()
                        print(f"  -> Success! Saved {len(valid_lines)} unique words.")
                    else:
                        print(f"  -> All generated words were duplicates or invalid. Skipping write.")

                except Exception as e:
                    print(f"  -> Error generating batch: {e}")

                time.sleep(1)
                current_batch += 1

    print("\nBulk generation complete!")


if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="Generate Cryptic German Crossword Clues using Claude.")
    parser.add_argument(
        "--hint-level",
        type=str,
        required=True,
        help="The CEFR difficulty level for the hints (e.g., A2, B2, C1)."
    )
    parser.add_argument(
        "--batch-size",
        type=int,
        default=10,
        help="The number of words to generate per theme (default: 10)."
    )
    parser.add_argument(
        "--themes",
        nargs="+",
        required=True,
        help='A list of themes separated by spaces. Enclose multi-word themes in quotes (e.g., "Food and Cooking" Travel).'
    )

    args = parser.parse_args()

    run_bulk_generation(args.hint_level, args.batch_size, args.themes)
